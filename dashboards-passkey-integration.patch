+import React, { useState, useEffect } from 'react';
+import {
+  EuiPage,
+  EuiPageBody,
+  EuiPageContent,
+  EuiPageContentHeader,
+  EuiPageContentHeaderSection,
+  EuiTitle,
+  EuiButton,
+  EuiBasicTable,
+  EuiSpacer,
+  EuiEmptyPrompt,
+  EuiLoadingSpinner,
+  EuiToast,
+  EuiGlobalToastList,
+  EuiConfirmModal,
+  EuiModal,
+  EuiModalHeader,
+  EuiModalHeaderTitle,
+  EuiModalBody,
+  EuiModalFooter,
+  EuiButtonEmpty,
+  EuiCompressedFormRow,
+  EuiCompressedFieldText,
+  EuiText,
+  EuiCallOut,
+} from '@elastic/eui';
+import { CoreStart } from '../../../../../src/core/public';
+import { PasskeyService } from '../../services/passkey-service';
+import { formatCredential, getWebAuthnErrorMessage, isWebAuthnSupported } from '../../utils/webauthn-helpers';
+
+interface PasskeyManagementPageProps {
+  http: CoreStart['http'];
+  username: string;
+}
+
+interface Toast {
+  id: string;
+  title: string;
+  color: 'success' | 'danger' | 'warning';
+  text?: string;
+}
+
+export function PasskeyManagementPage({ http, username }: PasskeyManagementPageProps) {
+  const [credentials, setCredentials] = useState<any[]>([]);
+  const [isLoading, setIsLoading] = useState(true);
+  const [toasts, setToasts] = useState<Toast[]>([]);
+  const [deleteModal, setDeleteModal] = useState<{ show: boolean; credentialId?: string; name?: string }>({
+    show: false,
+  });
+  const [registerModal, setRegisterModal] = useState(false);
+  const [friendlyName, setFriendlyName] = useState('');
+  const [isRegistering, setIsRegistering] = useState(false);
+  const [registerError, setRegisterError] = useState<string | null>(null);
+
+  const passkeyService = new PasskeyService(http);
+
+  useEffect(() => {
+    loadCredentials();
+  }, []);
+
+  const loadCredentials = async () => {
+    setIsLoading(true);
+    try {
+      const creds = await passkeyService.listPasskeys(username);
+      setCredentials(creds.map(formatCredential));
+    } catch (error) {
+      addToast('Error loading passkeys', 'danger', 'Failed to load your passkeys');
+    } finally {
+      setIsLoading(false);
+    }
+  };
+
+  const addToast = (title: string, color: 'success' | 'danger' | 'warning', text?: string) => {
+    const toast: Toast = {
+      id: `${Date.now()}`,
+      title,
+      color,
+      text,
+    };
+    setToasts([...toasts, toast]);
+  };
+
+  const removeToast = (removedToast: Toast) => {
+    setToasts(toasts.filter((toast) => toast.id !== removedToast.id));
+  };
+
+  const handleDelete = async () => {
+    if (!deleteModal.credentialId) return;
+
+    try {
+      const success = await passkeyService.deletePasskey(deleteModal.credentialId);
+      if (success) {
+        addToast('Passkey deleted', 'success', `${deleteModal.name} has been removed`);
+        loadCredentials();
+      } else {
+        addToast('Delete failed', 'danger', 'Failed to delete passkey');
+      }
+    } catch (error) {
+      addToast('Delete failed', 'danger', 'An error occurred while deleting the passkey');
+    } finally {
+      setDeleteModal({ show: false });
+    }
+  };
+
+  const handleRegister = async () => {
+    if (!friendlyName.trim()) {
+      setRegisterError('Please enter a name for your passkey');
+      return;
+    }
+
+    setIsRegistering(true);
+    setRegisterError(null);
+
+    try {
+      // Get registration options
+      const options = await passkeyService.getRegistrationOptions(username);
+
+      // Register passkey
+      const result = await passkeyService.registerPasskey(username, options, friendlyName);
+
+      if (result.success) {
+        addToast('Passkey registered', 'success', `${friendlyName} has been added`);
+        setRegisterModal(false);
+        setFriendlyName('');
+        loadCredentials();
+      } else {
+        setRegisterError(result.error || 'Registration failed');
+      }
+    } catch (error) {
+      setRegisterError(getWebAuthnErrorMessage(error));
+    } finally {
+      setIsRegistering(false);
+    }
+  };
+
+  const columns = [
+    {
+      field: 'friendlyName',
+      name: 'Name',
+      sortable: true,
+    },
+    {
+      field: 'createdAtFormatted',
+      name: 'Created',
+      sortable: true,
+    },
+    {
+      field: 'lastUsedAtFormatted',
+      name: 'Last Used',
+      sortable: true,
+    },
+    {
+      name: 'Actions',
+      actions: [
+        {
+          name: 'Delete',
+          description: 'Delete this passkey',
+          icon: 'trash',
+          type: 'icon',
+          color: 'danger',
+          onClick: (item: any) =>
+            setDeleteModal({ show: true, credentialId: item.id, name: item.friendlyName }),
+        },
+      ],
+    },
+  ];
+
+  if (!isWebAuthnSupported()) {
+    return (
+      <EuiPage>
+        <EuiPageBody>
+          <EuiPageContent>
+            <EuiEmptyPrompt
+              iconType="alert"
+              title={<h2>Passkeys Not Supported</h2>}
+              body={
+                <p>
+                  Your browser does not support passkeys. Please use a modern browser like Chrome,
+                  Firefox, Safari, or Edge.
+                </p>
+              }
+            />
+          </EuiPageContent>
+        </EuiPageBody>
+      </EuiPage>
+    );
+  }
+
+  return (
+    <>
+      <EuiPage>
+        <EuiPageBody>
+          <EuiPageContent>
+            <EuiPageContentHeader>
+              <EuiPageContentHeaderSection>
+                <EuiTitle>
+                  <h2>Manage Passkeys</h2>
+                </EuiTitle>
+              </EuiPageContentHeaderSection>
+              <EuiPageContentHeaderSection>
+                <EuiButton
+                  onClick={() => setRegisterModal(true)}
+                  fill
+                  iconType="plus"
+                  disabled={isLoading}
+                >
+                  Register New Passkey
+                </EuiButton>
+              </EuiPageContentHeaderSection>
+            </EuiPageContentHeader>
+
+            <EuiSpacer />
+
+            <EuiText size="s" color="subdued">
+              <p>
+                Passkeys allow you to sign in using your device's biometric authentication (Touch
+                ID, Face ID, Windows Hello) or a hardware security key.
+              </p>
+            </EuiText>
+
+            <EuiSpacer />
+
+            {isLoading ? (
+              <div style={{ textAlign: 'center', padding: '2rem' }}>
+                <EuiLoadingSpinner size="xl" />
+              </div>
+            ) : credentials.length === 0 ? (
+              <EuiEmptyPrompt
+                iconType="lock"
+                title={<h3>No Passkeys Registered</h3>}
+                body={
+                  <p>
+                    You haven't registered any passkeys yet. Click "Register New Passkey" to add
+                    one.
+                  </p>
+                }
+                actions={
+                  <EuiButton onClick={() => setRegisterModal(true)} fill iconType="plus">
+                    Register Your First Passkey
+                  </EuiButton>
+                }
+              />
+            ) : (
+              <EuiBasicTable items={credentials} columns={columns} />
+            )}
+          </EuiPageContent>
+        </EuiPageBody>
+      </EuiPage>
+
+      {/* Delete Confirmation Modal */}
+      {deleteModal.show && (
+        <EuiConfirmModal
+          title="Delete Passkey"
+          onCancel={() => setDeleteModal({ show: false })}
+          onConfirm={handleDelete}
+          cancelButtonText="Cancel"
+          confirmButtonText="Delete"
+          buttonColor="danger"
+        >
+          <p>
+            Are you sure you want to delete <strong>{deleteModal.name}</strong>? This action cannot
+            be undone.
+          </p>
+        </EuiConfirmModal>
+      )}
+
+      {/* Registration Modal */}
+      {registerModal && (
+        <EuiModal onClose={() => setRegisterModal(false)}>
+          <EuiModalHeader>
+            <EuiModalHeaderTitle>Register New Passkey</EuiModalHeaderTitle>
+          </EuiModalHeader>
+
+          <EuiModalBody>
+            <EuiText size="s">
+              <p>
+                Give your passkey a name to help you identify it later (e.g., "My iPhone", "My
+                YubiKey").
+              </p>
+            </EuiText>
+
+            <EuiSpacer size="m" />
+
+            <EuiCompressedFormRow label="Passkey Name" fullWidth>
+              <EuiCompressedFieldText
+                placeholder="e.g., My iPhone"
+                value={friendlyName}
+                onChange={(e) => setFriendlyName(e.target.value)}
+                onKeyPress={(e) => {
+                  if (e.key === 'Enter') {
+                    handleRegister();
+                  }
+                }}
+                disabled={isRegistering}
+                fullWidth
+              />
+            </EuiCompressedFormRow>
+
+            {registerError && (
+              <>
+                <EuiSpacer size="m" />
+                <EuiCallOut title="Registration Failed" color="danger" iconType="alert">
+                  <p>{registerError}</p>
+                </EuiCallOut>
+              </>
+            )}
+          </EuiModalBody>
+
+          <EuiModalFooter>
+            <EuiButtonEmpty onClick={() => setRegisterModal(false)} disabled={isRegistering}>
+              Cancel
+            </EuiButtonEmpty>
+            <EuiButton
+              onClick={handleRegister}
+              fill
+              isLoading={isRegistering}
+              disabled={!friendlyName.trim() || isRegistering}
+            >
+              {isRegistering ? 'Registering...' : 'Register'}
+            </EuiButton>
+          </EuiModalFooter>
+        </EuiModal>
+      )}
+
+      {/* Toast Notifications */}
+      <EuiGlobalToastList
+        toasts={toasts}
+        dismissToast={removeToast}
+        toastLifeTimeMs={5000}
+      />
+    </>
+  );
+}
