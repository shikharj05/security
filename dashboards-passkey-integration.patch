+
+import React, { useState, useEffect } from 'react';
+import {
+  EuiButton,
+  EuiCompressedFormRow,
+  EuiCompressedFieldText,
+  EuiModal,
+  EuiModalHeader,
+  EuiModalHeaderTitle,
+  EuiModalBody,
+  EuiModalFooter,
+  EuiButtonEmpty,
+  EuiText,
+  EuiSpacer,
+  EuiCallOut,
+} from '@elastic/eui';
+import { CoreStart } from '../../../../../src/core/public';
+import { PasskeyService } from '../../services/passkey-service';
+import { isWebAuthnSupported, getWebAuthnErrorMessage } from '../../utils/webauthn-helpers';
+
+interface PasskeyLoginButtonProps {
+  http: CoreStart['http'];
+  onSuccess: () => void;
+}
+
+export function PasskeyLoginButton({ http, onSuccess }: PasskeyLoginButtonProps) {
+  const [isSupported, setIsSupported] = useState(false);
+  const [showModal, setShowModal] = useState(false);
+  const [username, setUsername] = useState('');
+  const [isLoading, setIsLoading] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+
+  const passkeyService = new PasskeyService(http);
+
+  useEffect(() => {
+    setIsSupported(isWebAuthnSupported());
+  }, []);
+
+  const handlePasskeyLogin = async () => {
+    if (!username) {
+      setError('Please enter your username');
+      return;
+    }
+
+    setIsLoading(true);
+    setError(null);
+
+    try {
+      // Get authentication options
+      const options = await passkeyService.getAuthenticationOptions(username);
+
+      // Authenticate with passkey
+      const result = await passkeyService.authenticateWithPasskey(username, options);
+
+      if (result.success) {
+        setShowModal(false);
+        onSuccess();
+      } else {
+        setError(result.error || 'Authentication failed');
+      }
+    } catch (err) {
+      console.error('Passkey login error:', err);
+      setError(getWebAuthnErrorMessage(err));
+    } finally {
+      setIsLoading(false);
+    }
+  };
+
+  if (!isSupported) {
+    return null;
+  }
+
+  return (
+    <>
+      <EuiCompressedFormRow>
+        <EuiButton
+          data-test-subj="passkey-login-button"
+          aria-label="passkey_login_button"
+          size="s"
+          iconType="fingerprint"
+          onClick={() => setShowModal(true)}
+          className="btn-login"
+        >
+          Sign in with Passkey
+        </EuiButton>
+      </EuiCompressedFormRow>
+
+      {showModal && (
+        <EuiModal onClose={() => setShowModal(false)}>
+          <EuiModalHeader>
+            <EuiModalHeaderTitle>Sign in with Passkey</EuiModalHeaderTitle>
+          </EuiModalHeader>
+
+          <EuiModalBody>
+            <EuiText size="s">
+              <p>
+                Use your device's biometric authentication (Touch ID, Face ID, Windows Hello) or
+                security key to sign in.
+              </p>
+            </EuiText>
+
+            <EuiSpacer size="m" />
+
+            <EuiCompressedFormRow label="Username" fullWidth>
+              <EuiCompressedFieldText
+                data-test-subj="passkey-username"
+                placeholder="Enter your username"
+                value={username}
+                onChange={(e) => setUsername(e.target.value)}
+                onKeyPress={(e) => {
+                  if (e.key === 'Enter') {
+                    handlePasskeyLogin();
+                  }
+                }}
+                disabled={isLoading}
+                fullWidth
+              />
+            </EuiCompressedFormRow>
+
+            {error && (
+              <>
+                <EuiSpacer size="m" />
+                <EuiCallOut title="Authentication Failed" color="danger" iconType="alert">
+                  <p>{error}</p>
+                </EuiCallOut>
+              </>
+            )}
+          </EuiModalBody>
+
+          <EuiModalFooter>
+            <EuiButtonEmpty onClick={() => setShowModal(false)} disabled={isLoading}>
+              Cancel
+            </EuiButtonEmpty>
+            <EuiButton
+              onClick={handlePasskeyLogin}
+              fill
+              isLoading={isLoading}
+              disabled={!username || isLoading}
+            >
+              {isLoading ? 'Authenticating...' : 'Continue'}
+            </EuiButton>
+          </EuiModalFooter>
+        </EuiModal>
+      )}
+    </>
+  );
+}
